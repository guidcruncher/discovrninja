    <form class="d-flex" role="search">
      <input class="form-control me-2" id="q" type="text" placeholder="Search" aria-label="Search">
      <button class="btn btn-primary" type="button" onclick="doSearch('#q');return false;">Search</button>
    </form>
    <script type="text/javascript">
      ui("#q").enterCheck({
        onEnterKey: function () {
          doSearch('#q')
        }
      });

    </script>
